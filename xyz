#!/usr/bin/env python3
def get_number(prompt):
    while True:
        raw = input(prompt).strip()
        try:
            return float(raw) if "." in raw else int(raw)
        except ValueError:
            print("Invalid input")


def to_lock_digits(n):
    n = int(round(n))
    if n < 0:
        n = -n
    n = n % 60
    return f"{n:02d}"


def main():
    x = get_number("x: ")
    y = get_number("y: ")
    z = get_number("z: ")

    eq1 = 2 * x + 11
    eq2 = (2 * z + y) - 5
    eq3 = (y + z) - x

    result = to_lock_digits(eq1) + to_lock_digits(eq2) + to_lock_digits(eq3)

    print(f"\n{result}")


if __name__ == "__main__":
    main()